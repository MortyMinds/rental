# Rental Scraper Configuration

# Comma-separated list of locations (e.g., "90210")
RENTAL_ZIPCODES=90210

# Price Range
MIN_PRICE=2000
MAX_PRICE=5000

# Bedrooms and Bathrooms
MIN_BEDS=2
MIN_BATHS=1.5

# ADVANCED: Explicit base URLs (overrides location-based generation)
# ZILLOW_BASE_URL=https://www.zillow.com/homes/for_rent/custom-search/
# REDFIN_BASE_URL=https://www.redfin.com/custom-rentals

# Scraper Bypass Prefix: jina, markdown, defuddle (optional)
# SCRAPER_BYPASS_PREFIX=jina
